{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "",
  "cli": {
    "analytics": false
  },
  "projects": {
    "app": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:application": {
          "strict": true
        }
      },
      "root": ".",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-builders/custom-webpack:browser",
          "options": {
            "customWebpackConfig": {
              "path": "./webpack.ng-renderer.cjs",
              "mergeStrategies": {
                "module": "merge",
                "plugins": "append"
              }
            },
            "outputPath": "build",
            "index": "src/index.html",
            "main": "src/app/main.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": [
              { "glob": "**/*", "input": "src/images", "output": "images" },
              { "glob": "**/*", "input": "src/locales", "output": "locales" }
            ],
            "styles": ["src/scss/styles.scss"],
            "scripts": []
          }
        },
        "build-main": {
          "builder": "@angular-builders/custom-webpack:browser",
          "options": {
            "customWebpackConfig": {
              "path": "./webpack.main.cjs",
              "mergeStrategies": {
                "entry": "replace",
                "output": "replace",
                "target": "replace",
                "module": "replace",
                "plugins": "replace",
                "externals": "replace",
                "optimization": "replace",
                "node": "replace"
              }
            },
            "main": "src/main.ts",
            "tsConfig": "tsconfig.json",
            "outputPath": "build"
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": ["src/**/*.ts", "src/**/*.html", "jslib/**/*.ts", "*.ts", "*.mjs"]
          }
        },
        "test": {
          "builder": "@angular-builders/jest:run",
          "options": {
            "config": "jest.config.cjs"
          }
        }
      }
    }
  }
}
