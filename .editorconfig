# EditorConfig is awesome: http://EditorConfig.org

# top-most EditorConfig file
root = true

# Don't use tabs for indentation.
[*]
indent_size = 4
indent_style = space
tab_width = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
guidelines = 120

# JSON files
[*.json]
indent_size = 2

# JS files
[*.{js,ts,scss,html}]
indent_size = 2

[*.{ts}]
quote_type = single

[*.{scss,yml}]
indent_size = 2
