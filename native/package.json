{
  "name": "dc-native",
  "version": "1.0.0",
  "description": "Native keychain bindings for Bitwarden Directory Connector",
  "type": "module",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "GPL-3.0",
  "napi": {
    "binaryName": "dc_native",
    "targets":[
	"aarch64-apple-darwin",
	"x86_64-apple-darwin",
	"universal-apple-darwin",
	"aarch64-pc-windows-msvc",
	"aarch64-unknown-linux-gnu"
    ],
    "constEnum": "true"
  },
  "scripts": {
    "build": "napi build --platform --esm",
    "build:release": "napi build --platform --release --esm",
    "build:release:arm64": "napi build --platform --release --esm --target aarch64-apple-darwin",
    "universal": "napi universalize"
  },
  "devDependencies": {
    "@napi-rs/cli": "3.0.0"
  }
}
